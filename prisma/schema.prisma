generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  password       String
  phone          String
  role           String        @default("user") // "user" or "superadmin"
  isApproved     Boolean       @default(false)
  aadharImgUrl   String
  aadharPublicId String?
  panImgUrl      String
  panPublicId    String?
  otp            String?
  otpExpires     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  chitMembers    ChitMember[]
  payments       Payment[]
}

model Chit {
  id                  String        @id @default(uuid())
  name                String
  totalMembers        Int
  chitValue           Float
  monthlyContribution Float
  durationMonths      Int
  termsAndConditions  String        @default("")
  status              String        @default("upcoming") // "upcoming", "active", "completed"
  currentMonth        Int           @default(1)
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  members             ChitMember[]
  payments            Payment[]
}

model ChitMember {
  id        String   @id @default(uuid())
  chitId    String
  userId    String
  status    String   @default("pending") // "pending", "approved", "rejected"
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chit      Chit     @relation(fields: [chitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chitId, userId]) // A user can only join a chit once
}

model Payment {
  id            String    @id @default(uuid())
  userId        String
  chitId        String
  monthNumber   Int
  amount        Float
  transactionId String
  proofImgUrl   String
  proofPublicId String?
  status        String    @default("pending") // "pending", "approved", "rejected"
  remarks       String    @default("")
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chit          Chit      @relation(fields: [chitId], references: [id], onDelete: Cascade)

  @@unique([userId, chitId, monthNumber]) // Prevent duplicate submissions for same user, chit, and month
}
